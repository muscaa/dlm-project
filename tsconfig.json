{
    "include": [
        "**/*.ts",
        "**/*.tsx",
    ],
    "compilerOptions": {
        "target": "ES2022",
        "jsx": "react-jsx",
        "module": "ESNext",
        "paths": {
            "@client/*": [
                "./src/lib/client/*"
            ],
            "@server/*": [
                "./src/lib/server/*"
            ],
            "@shared/*": [
                "./src/lib/shared/*"
            ],
            "@type/*": [
                "./src/lib/type/*"
            ],
            "@/*": [
                "./src/*"
            ],
            ":/*": [
                "./public/*"
            ]
        },
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "vite/client"
        ],
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": false,
        "allowJs": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        /* Linting */
        "skipLibCheck": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true
    }
}